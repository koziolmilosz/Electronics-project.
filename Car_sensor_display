#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// --- SHORTENED BITMAP (placeholder, replace if needed) ---
const uint8_t mazdaLogo[] PROGMEM = {
  0x00, 0x00, 0xFF, 0xFF, 0x00, 0x00
};

// --- Analog pins ---
const int analogVoltagePin = A3;
const int analogCoolantPin = A1;
const int analogOilPin     = A2;   // was intake

// --- PWM ---
const int pwmPin = 9;

// --- Voltage settings ---
const float voltageDividerRatio = 4.75;
const float voltageThreshold = 15.0;

// --- Bias resistors ---
float biasCoolantResistor = 2400.0;
float biasOilResistor     = 2400.0;

// --- Coolant calibration (UNCHANGED) ---
const float coolantCalib[3][2] = {
  {37000, 20},
  {5300,  70},
  {3800,  80}
};

// --- 5-point logarithmic OIL table ---
const float oilCalib[5][2] = {
  {100000, -20},
  {30000,   0},
  {10000,  40},
  {3000,   80},
  {1000,  120}
};

// --- Display bar settings ---
const int barMaxWidth = 120;
const int barHeight = 10;
const int coolantMinTemp = 30;
const int coolantMaxTemp = 130;

bool blinkState = false;

// --- Convert ADC to resistance ---
float analogToResistance(int analogValue, float biasResistor) {
  float voltage = analogValue * (5.0 / 1023.0);
  return (biasResistor * voltage) / (5.0 - voltage);
}

// --- 3-point interpolation (coolant) ---
float calibrateTemperature(float resistance, const float table[3][2]) {
  if (resistance > table[0][0]) {
    float R1 = table[0][0], T1 = table[0][1];
    float R2 = table[1][0], T2 = table[1][1];
    return T1 + (resistance - R1) * (T2 - T1) / (R2 - R1);
  }

  if (resistance < table[2][0]) {
    float R1 = table[1][0], T1 = table[1][1];
    float R2 = table[2][0], T2 = table[2][1];
    return T1 + (resistance - R1) * (T2 - T1) / (R2 - R1);
  }

  for (int i = 0; i < 2; i++) {
    if (resistance <= table[i][0] && resistance >= table[i + 1][0]) {
      float R1 = table[i][0], T1 = table[i][1];
      float R2 = table[i + 1][0], T2 = table[i + 1][1];
      return T1 + (resistance - R1) * (T2 - T1) / (R2 - R1);
    }
  }

  return table[1][1];
}

// --- 5-point LOG interpolation (oil) ---
float calibrateOilTemp(float resistance) {
  for (int i = 0; i < 4; i++) {
    if (resistance <= oilCalib[i][0] && resistance >= oilCalib[i + 1][0]) {
      float logR  = log(resistance);
      float logR1 = log(oilCalib[i][0]);
      float logR2 = log(oilCalib[i + 1][0]);

      float T1 = oilCalib[i][1];
      float T2 = oilCalib[i + 1][1];

      return T1 + (logR - logR1) * (T2 - T1) / (logR2 - logR1);
    }
  }

  return oilCalib[2][1]; // fallback
}

void setup() {
  Serial.begin(9600);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("SSD1306 failed"));
    for (;;);
  }

  display.clearDisplay();
  display.drawBitmap(0, 0, mazdaLogo, 128, 64, SSD1306_WHITE);
  display.display();
  delay(1500);

  pinMode(pwmPin, OUTPUT);
}

void loop() {
  // --- Read inputs ---
  int analogVoltage = analogRead(analogVoltagePin);
  int analogCoolant = analogRead(analogCoolantPin);
  int analogOil     = analogRead(analogOilPin);

  // --- Convert to resistance ---
  float coolantResistance = analogToResistance(analogCoolant, biasCoolantResistor);
  float oilResistance     = analogToResistance(analogOil, biasOilResistor);

  // --- Convert to temp ---
  float coolantTemp = calibrateTemperature(coolantResistance, coolantCalib);
  float oilTemp     = calibrateOilTemp(oilResistance);

  // --- Voltage ---
  float inputVoltage = analogVoltage * (5.0 / 1023.0);
  float outputVoltage = inputVoltage * voltageDividerRatio;

  // --- Bar ---
  int coolantBarWidth = map(coolantTemp, coolantMinTemp, coolantMaxTemp, 0, barMaxWidth);
  coolantBarWidth = constrain(coolantBarWidth, 0, barMaxWidth);

  // --- Blink ---
  if (coolantTemp > 115) {
    blinkState = !blinkState;
  } else {
    blinkState = true;
  }

  // --- Display ---
  display.clearDisplay();
  display.setTextSize(2);
  display.setTextColor(SSD1306_WHITE);

  // Battery
  display.setCursor(0, 0);
  display.print("Batt:");
  display.print(outputVoltage, 1);
  display.print("V");

  // OIL (was IAT)
  display.setCursor(0, 19);
  display.print("OIL:");
  display.print(oilTemp, 1);
  display.print((char)247);
  display.print("C");

  // Coolant
  display.setCursor(0, 39);
  display.print("CLT:");
  display.print(coolantTemp, 1);
  display.print((char)247);
  display.print("C");

  // Bar
  if (blinkState) {
    display.drawRect(4, 55, barMaxWidth, barHeight, SSD1306_WHITE);
    display.fillRect(4, 55, coolantBarWidth, barHeight, SSD1306_WHITE);
  }

  display.display();

  // PWM control
  if (outputVoltage > voltageThreshold) {
    digitalWrite(pwmPin, LOW);
  } else {
    analogWrite(pwmPin, 108);
  }

  delay(100);
}
